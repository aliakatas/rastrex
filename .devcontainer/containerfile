FROM docker.io/library/ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

# Core build tools + GDAL dev packages
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    ninja-build \
    git \
    curl \
    ca-certificates \
    pkg-config \
    gdb \
    lldb \
    # lldb-dap \
    clangd \
    clang-format \
    clang-tidy \
    libgdal-dev \
    # gdal-bin \
    # python3-gdal \
    && rm -rf /var/lib/apt/lists/*

# Create a non-root user for development.
# Match USER_UID/USER_GID to the host user so bind-mounted /workspace is writable
# (Dev Containers passes these via build.args from localEnv, or defaults below).
ARG USERNAME=dev
ARG USER_UID=1000
ARG USER_GID=${USER_UID}

# Avoid groupadd failure when GID already exists (e.g. macOS staff gid 20 == Ubuntu dialout)
RUN if ! getent group "${USER_GID}" >/dev/null; then \
      groupadd --gid "${USER_GID}" "${USERNAME}"; \
    fi \
    && useradd --uid "${USER_UID}" --gid "${USER_GID}" -m "${USERNAME}" \
    && apt-get update \
    && apt-get install -y sudo \
    && echo "${USERNAME} ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers.d/${USERNAME} \
    && chmod 0440 /etc/sudoers.d/${USERNAME} \
    && rm -rf /var/lib/apt/lists/*

USER ${USERNAME}
WORKDIR /workspace
